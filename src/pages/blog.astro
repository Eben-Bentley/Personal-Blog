---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

interface BlogPost {
  title: string;
  date: string;
  description: string;
  slug: string;
  tags?: string[];
}

const blogPosts: BlogPost[] = [
  {
    title: 'Getting Started with Go Concurrency',
    date: '2026-01-13',
    description: 'Learn the fundamentals of concurrent programming in Go using goroutines and channels. Explore patterns and best practices for building scalable applications.',
    slug: 'go-concurrency-basics',
    tags: ['Go', 'Concurrency', 'Backend'],
  },
  {
    title: 'Building High-Performance REST APIs',
    date: '2026-01-10',
    description: 'Design patterns and best practices for building scalable REST APIs. Covers performance optimization, caching strategies, and API versioning.',
    slug: 'building-rest-apis',
    tags: ['APIs', 'Backend', 'Performance'],
  },
];

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<Layout
  title="Blog - Eben Bentley"
  name="Eben Bentley"
  description="Technical articles about software engineering, cloud infrastructure, and full-stack development."
>
  <Navbar name="Eben Bentley" currentPath="/blog" />

  <div class="container max-w-4xl mx-auto px-8 py-16 sm:px-4">
    <div class="space-y-2 mb-12">
      <h1 class="text-5xl sm:text-4xl font-bold text-text-primary">Blog</h1>
      <p class="text-lg text-text-secondary">
        Technical articles and insights about software engineering, cloud infrastructure, and development practices.
      </p>
    </div>

    <div class="space-y-8">
      {blogPosts.map((post) => (
        <article class="group p-6 rounded-lg border border-border bg-card hover:border-accent transition-all duration-300 hover:shadow-lg">
          <a href={`/blog/${post.slug}`} class="no-underline block">
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-sm text-text-secondary">
                <time datetime={post.date}>{formatDate(post.date)}</time>
                {post.tags && post.tags.length > 0 && (
                  <>
                    <span class="text-border">•</span>
                    <div class="flex gap-2">
                      {post.tags.map((tag) => (
                        <span class="px-2 py-0.5 rounded-full bg-accent/10 text-accent text-xs font-medium">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </>
                )}
              </div>

              <h2 class="text-2xl sm:text-xl font-bold text-text-primary group-hover:text-accent transition-colors duration-200">
                {post.title}
              </h2>

              <p class="text-text-secondary leading-relaxed">
                {post.description}
              </p>

              <div class="flex items-center gap-2 text-accent font-medium text-sm">
                Read more
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    {blogPosts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-text-secondary text-lg">No blog posts yet. Check back soon!</p>
      </div>
    )}
  </div>
</Layout>

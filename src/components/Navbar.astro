---
interface Props {
  name: string;
  currentPath?: string;
}

const { name, currentPath = '/' } = Astro.props;
---

<header class="sticky top-0 z-[100] border-b border-border shadow-md" style="background: var(--bg-card); backdrop-filter: blur(10px); box-shadow: 0 2px 8px var(--shadow);">
  <div class="max-w-[1400px] mx-auto px-8 py-4 flex justify-between items-center sm:px-4 sm:py-3">
    <a href="/" class="no-underline">
      <span class="text-xl sm:text-lg font-bold text-text-primary tracking-tight">{name}</span>
    </a>

  </div>
</header>
